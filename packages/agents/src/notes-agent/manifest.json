{
  "name": "notes_agent",
  "version": "1.0.0",
  "description": "Creates structured notes, flashcards, and summaries from lesson content. Supports Cornell and Zettelkasten formats.",
  "capabilities": ["take_notes", "create_flashcards", "cornell_notes", "zettelkasten"],
  "requiredProviders": ["openai", "anthropic"],
  "minModelCapabilities": ["text-generation"],
  "inputSchema": {
    "type": "object",
    "properties": {
      "content": { "type": "string" },
      "format": { "type": "string", "enum": ["cornell", "zettelkasten", "flashcards"] }
    },
    "required": ["content"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "text": { "type": "string" },
      "notes": { "type": "object" },
      "format": { "type": "string" }
    }
  }
}
