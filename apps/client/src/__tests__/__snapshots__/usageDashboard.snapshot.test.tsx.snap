// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`UsageDashboard > renders stable layout for 7/30 day tabs 1`] = `"<div><div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-card p-6 space-y-4"><div class="flex items-start justify-between gap-3"><div><h2 class="text-lg font-semibold text-gray-900 dark:text-white">Usage</h2><p class="text-xs text-gray-800/80 dark:text-gray-200">Token counts are an estimate. Costs vary by provider/model.</p></div><div class="flex items-center gap-2"><button type="button" class="px-3 py-1.5 rounded-xl text-sm border bg-accent text-white border-accent">7 days</button><button type="button" class="px-3 py-1.5 rounded-xl text-sm border bg-gray-50 dark:bg-gray-800 text-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700">30 days</button></div></div><div class="text-sm text-gray-800/80 dark:text-gray-200 flex items-center justify-between"><span>Total tokens</span><span class="font-mono">123</span></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div class="p-3 bg-gray-50 dark:bg-gray-800 rounded-xl"><div class="text-xs text-gray-500 dark:text-gray-300">Providers</div><div class="mt-2"><div class="space-y-2"><div class="p-3 bg-gray-50 dark:bg-gray-800 rounded-xl"><div class="flex items-center justify-between"><div class="text-sm font-medium text-gray-900 dark:text-white capitalize">openai</div><div class="font-mono text-sm text-gray-700 dark:text-gray-200">123</div></div><div class="mt-1 text-xs text-gray-500 dark:text-gray-300 flex flex-wrap gap-x-4 gap-y-1"><span>Calls: 3</span><span>Last used: 3/24/2026</span></div></div></div></div></div><div class="p-3 bg-gray-50 dark:bg-gray-800 rounded-xl"><div class="text-xs text-gray-500 dark:text-gray-300">Top agents</div><div class="mt-2"><ul class="space-y-1"><li class="flex items-center justify-between text-sm"><span class="text-gray-900 dark:text-white">course_builder</span><span class="font-mono text-gray-700 dark:text-gray-200">90</span></li></ul></div></div></div></div></div>"`;
